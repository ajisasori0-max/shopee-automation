# Shopee API Credentials Template
# Copy this file to .env and fill in your actual values

# =============================================================================
# REQUIRED: Get these from https://open.shopee.com
# =============================================================================

# Your Partner ID (numeric, e.g., 123456)
SHOPEE_PARTNER_ID=your_partner_id_here

# Your Partner Key (long secret string, keep this safe!)
SHOPEE_PARTNER_KEY=your_partner_key_here

# Your Shop ID (numeric, from Seller Center)
SHOPEE_SHOP_ID=your_shop_id_here

# Region code: id (Indonesia), sg, my, th, vn, ph, tw, br, mx, co, cl, pl
SHOPEE_REGION=id

# =============================================================================
# OPTIONAL: These will be generated automatically after OAuth
# =============================================================================

# Access token (4-hour lifetime) - generated by get_token.py
SHOPEE_ACCESS_TOKEN=

# Refresh token (30-day lifetime) - generated by get_token.py  
SHOPEE_REFRESH_TOKEN=

# =============================================================================
# ADVANCED: Only change if you know what you're doing
# =============================================================================

# Base URL for API calls (usually don't change this)
SHOPEE_BASE_URL=https://partner.shopeemobile.com/api/v2

# Redirect URI for OAuth callback (must match your app settings)
SHOPEE_REDIRECT_URI=http://localhost:8080/callback
